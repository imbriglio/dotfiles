[user]
    name = Jodie Imbriglio
    email = imbriglio@gmail.com

[core]
    editor = code --wait
    autocrlf = input

[pull]
    rebase = true

[init]
    defaultBranch = main

[alias]
    st = status
    co = checkout
    br = branch
    cm = commit
    ps = push
    pl = pull
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    last = log -1 HEAD

[color]
    ui = auto

[diff]
    tool = default-difftool

[merge]
    tool = default-mergetool
